# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.

# Supabase — get these from: Supabase Dashboard → Project Settings → API
# Only use the ANON (public) key here. NEVER put the service_role key in frontend code.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Razorpay — Key ID only (safe for frontend). Never put the secret here.
VITE_RAZORPAY_KEY_ID=your-razorpay-key-id-here
